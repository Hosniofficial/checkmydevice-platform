{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/dashboard",       "destination": "/index.html" },
    { "source": "/dashboard/(.*)", "destination": "/index.html" },
    { "source": "/reports",         "destination": "/index.html" },
    { "source": "/reports/(.*)",   "destination": "/index.html" },
    { "source": "/notifications",   "destination": "/index.html" },
    { "source": "/profile",         "destination": "/index.html" },
    { "source": "/admin",           "destination": "/index.html" },
    { "source": "/admin/(.*)",     "destination": "/index.html" },
    { "source": "/login",           "destination": "/index.html" },
    { "source": "/register",        "destination": "/index.html" },
    { "source": "/forgot-password", "destination": "/index.html" },
    { "source": "/reset-password",  "destination": "/index.html" },
    { "source": "/verify-email",    "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
