{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/assets/(.*)", "headers": { "Cache-Control": "public, max-age=31536000, immutable" }, "continue": true },

    { "src": "/(.*)", "headers": { "X-Frame-Options": "DENY", "X-Content-Type-Options": "nosniff", "Referrer-Policy": "strict-origin-when-cross-origin" }, "continue": true },

    { "src": "/dashboard",       "dest": "/index.html" },
    { "src": "/dashboard/(.*)", "dest": "/index.html" },
    { "src": "/reports",         "dest": "/index.html" },
    { "src": "/reports/(.*)",   "dest": "/index.html" },
    { "src": "/notifications",   "dest": "/index.html" },
    { "src": "/profile",         "dest": "/index.html" },
    { "src": "/admin",           "dest": "/index.html" },
    { "src": "/admin/(.*)",     "dest": "/index.html" },
    { "src": "/login",           "dest": "/index.html" },
    { "src": "/register",        "dest": "/index.html" },
    { "src": "/forgot-password", "dest": "/index.html" },
    { "src": "/reset-password",  "dest": "/index.html" },
    { "src": "/verify-email",    "dest": "/index.html" },

    { "handle": "filesystem" },

    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ]
}
