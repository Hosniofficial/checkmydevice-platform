# ─── Server ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/checkmydevice

# ─── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=30d

# ─── Email (Resend API — HTTP-based, no SMTP ports needed) ───────
# Get free API key from https://resend.com (3,000 emails/month free)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=CheckMyDevice <noreply@yourdomain.com>

# ─── Device Lookup (IMEI APIs) ────────────────────────────────────
# Options: imeicheck | devicedecoder | mock (for development)
IMEI_PROVIDER=mock
IMEICHECK_API_KEY=your_imeicheck_api_key
IMEICHECK_API_URL=https://alpha.imeicheck.com
DEVICEDECODER_API_KEY=your_devicedecoder_api_key

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Frontend URL (CORS) ──────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Cloudinary (File Storage) ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Get DSN from https://sentry.io
SENTRY_DSN=

# ─── First Admin (used by seed.js only) ───────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisPassword123
